programa {
  funcao inicio() {
    real peso, distancia, volume, soma, sub, mult, div, frete
    	escreva("Digite o peso: ")
		leia(peso)
		escreva("Digite a distancia: ")
		leia(distancia)
    escreva("digite o volume: ")
    leia(volume)
    frete = 15 + (2*peso+0.05*distancia+10*volume)
    escreva(frete)
    //soma = a + b 
		//sub  = a - b
		//mult = a * b 
	  //div  = a / b
	

  }
}
