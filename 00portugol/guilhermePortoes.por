programa {
  funcao inicio() {
    inteiro clt
    inteiro estagiario
    inteiro pj
    inteiro totalDevs
    escreva("Digite o total de clt: ")
		leia(clt)
		escreva("Digite o total de estagiarios: ")
		leia(estagiario)
    escreva("digite o total de pjs: ")
    leia(pj)


    totalDevs= clt+ estagiario+ pj
    escreva(totalDevs)
  }
}
